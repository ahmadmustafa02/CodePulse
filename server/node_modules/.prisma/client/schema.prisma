generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  githubInstallationId Int      @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  repositories Repository[]
  developers   Developer[]
  pullRequests PullRequest[]
  issues       Issue[]
}

model Repository {
  id             String   @id @default(cuid())
  githubRepoId   BigInt   @unique
  name           String
  fullName       String   @unique
  private        Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  pullRequests PullRequest[]
}

model Developer {
  id             String   @id @default(cuid())
  githubLogin    String
  githubUserId   BigInt
  avatarUrl      String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  pullRequests PullRequest[]
  issues       Issue[]

  @@unique([githubLogin, organizationId])
}

model PullRequest {
  id             String   @id @default(cuid())
  githubPrId     BigInt
  prNumber       Int
  title          String
  headSha        String
  baseBranch     String
  headBranch     String
  state          String   @default("open")
  organizationId String
  repositoryId   String
  developerId    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  repository   Repository   @relation(fields: [repositoryId], references: [id])
  developer    Developer    @relation(fields: [developerId], references: [id])
  issues       Issue[]

  @@unique([githubPrId, repositoryId])
}

model Issue {
  id             String   @id @default(cuid())
  file           String
  line           Int
  category       String
  severity       String
  title          String
  explanation    String
  suggestion     String
  codeSnippet    String
  organizationId String
  pullRequestId  String
  developerId    String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  pullRequest  PullRequest  @relation(fields: [pullRequestId], references: [id])
  developer    Developer    @relation(fields: [developerId], references: [id])
}

model DigestLog {
  id             String   @id @default(cuid())
  organizationId String
  developerId    String
  sentAt         DateTime @default(now())
  issueCount     Int
  weekStart      DateTime
  weekEnd        DateTime
}

model User {
  id             String   @id @default(cuid())
  githubLogin    String   @unique
  githubUserId   BigInt   @unique
  avatarUrl      String?
  email          String?
  installationId Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
