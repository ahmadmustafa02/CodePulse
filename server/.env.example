# Node environment: development | production | test
NODE_ENV=development

# HTTP port for the API server
PORT=3001

# GitHub App webhook secret (min 20 chars)
GITHUB_WEBHOOK_SECRET=replace_with_webhook_secret

# GitHub App (for PR reviews and installation callbacks)
GITHUB_APP_ID=000000
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# GitHub OAuth App (separate from GitHub App — user sign-in)
# Create at: GitHub → Settings → Developer settings → OAuth Apps
# Homepage URL: http://localhost:8080 (local) or https://getcodepulse.vercel.app (prod)
# Callback URL must match where the browser hits /auth/github/callback (use Vercel proxy in prod)
GITHUB_OAUTH_CLIENT_ID=your_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback
# Production example:
# GITHUB_OAUTH_CALLBACK_URL=https://getcodepulse.vercel.app/api/v1/auth/github/callback

# Groq API key for LLM reviews
GROQ_API_KEY=gsk_replace_me

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# Resend email API
RESEND_API_KEY=re_replace_me
DIGEST_FROM_EMAIL=CodePulse <reviews@yourdomain.com>
DIGEST_CRON_SECRET=replace_with_random_secret_min_20_chars
# GitHub Actions (weekly-digest workflow): set repo secrets CODEPULSE_API_URL (Azure API base, no trailing slash) and DIGEST_CRON_SECRET (same value as here)

# Session cookie signing secret (min 32 chars)
AUTH_SECRET=replace_with_random_secret_min_32_chars

# Web app origin (CORS + post-auth redirects)
WEB_APP_URL=http://localhost:8080
# Production: WEB_APP_URL=https://getcodepulse.vercel.app
# GitHub App setup / post-install callback (prod):
# https://getcodepulse.vercel.app/api/v1/auth/installation/callback
