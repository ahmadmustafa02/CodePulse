
# Node environment: development | production | test
NODE_ENV=development

# HTTP port for the API server
PORT=3001

# Secret GitHub uses to sign webhook deliveries (create a long random string, 20+ chars)
GITHUB_WEBHOOK_SECRET=replace_with_a_long_random_secret_min_20_chars

# GitHub App numeric ID from the app settings page
GITHUB_APP_ID=000000

# GitHub App private key PEM (use \n for newlines in a single-line env value, or a secrets manager)
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# OAuth app credentials for GitHub login/install flows
GITHUB_CLIENT_ID=Iv1.0000000000000000
GITHUB_CLIENT_SECRET=ghp_replace_with_oauth_client_secret

# Groq API key for LLM calls
GROQ_API_KEY=gsk_replace_with_groq_key

# Primary database connection string (Postgres, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/codepulse
